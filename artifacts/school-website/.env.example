# Base URL of the deployed Express backend (no trailing slash).
# Leave EMPTY to use a same-origin /api path (works on Replit where the
# api-server is proxied at /api).
#
# Example for split deployment (frontend on Vercel, backend on Render/Railway):
#   VITE_API_URL=https://ska-api.onrender.com
VITE_API_URL=
